# Python bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Distribution / packaging
build/
dist/
*.egg-info/
.eggs/

# Test / type checker caches
.pytest_cache/
.mypy_cache/
.pytype/
.cache/

# IDEs / editors
.idea/
.vscode/

# OS files
.DS_Store
Thumbs.db

# Logs / temp files
*.log
*.tmp
*.temp

# Project outputs (keep folders with .gitkeep)
output/*
extracted/*
!output/.gitkeep
!extracted/.gitkeep
